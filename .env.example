OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://host.docker.internal:1234/v1

CHAT_MODEL=qwen/qwen3-4b-2507
EMBEDDING_MODEL=text-embedding-all-minilm-l6-v2-embedding
CHAT_TEMPERATURE=0.0
CHAT_MAX_TOKENS=8000
CHAT_TOP_P=0.90

A2A_PROTOCOL_ENABLED=true
A2A_TIMEOUT=180
A2A_RETRY_LIMIT=3

MODERATION_CHECKPOINT_DB=/app/shared_db/moderation_checkpoints.db
DATABASE_URL=sqlite:////app/shared_db/mvp_database.db
BFA_SERVICE_URL=http://bfa-service:8001
ANALYST_AGENT_URL=http://analyst-agent:5001

CORS_ALLOW_ORIGINS=*
LOG_LEVEL=INFO
