NOOSPHERA_0.4_ROOT=/media/yuri/Noosphera/Noosphera_0.4

# -----------------------------------------------------------------------------
# LLM BACKEND (LM-Studio)
# -----------------------------------------------------------------------------
OPENAI_API_KEY="lm-studio"
OPENAI_BASE_URL="http://192.168.15.7:1234/v1"

CHAT_MODEL="qwen/qwen3-4b-2507"
EMBEDDING_MODEL="text-embedding-all-minilm-l6-v2-embedding"

CHAT_TEMPERATURE=0.0
CHAT_MAX_TOKENS=8000
CHAT_TOP_P=0.90

# -----------------------------------------------------------------------------
# A2A COMMUNICATION
# -----------------------------------------------------------------------------
A2A_PROTOCOL_ENABLED=true
A2A_TIMEOUT=180
A2A_RETRY_LIMIT=3

# -----------------------------------------------------------------------------
# PREFECT
# -----------------------------------------------------------------------------
PREFECT_PORT=4200
PREFECT_API_URL=http://prefect-server:${PREFECT_PORT}/api

# -----------------------------------------------------------------------------
# LANGGRAPH / LANGCHAIN OBSERVABILITY
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=noosphera_0.4

LANGGRAPH_CHECKPOINTER=postgres
LANGGRAPH_STORE=postgres

# -----------------------------------------------------------------------------
# MEMORY & VECTOR SEARCH
# -----------------------------------------------------------------------------
MEMORY_ENABLED=true
CHECKPOINT_ENABLED=true
VECTORSTORE_ENABLED=true
KNOWLEDGE_GRAPH_ENABLED=true

VECTOR_DIMENSION=384
VECTOR_INDEX_TYPE=hnsw

# -----------------------------------------------------------------------------
# SYSTEM
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
